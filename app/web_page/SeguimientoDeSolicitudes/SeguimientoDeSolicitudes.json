    "agregarEstatusSolicitudVacaciones" : {
      "type" : "expression",
      "value" : [
        "if($data.hasOwnProperty('solicitudVacaciones') && $data.solicitudVacaciones) {",
        "  for (let solicitud of $data.solicitudVacaciones) {",
        "    if(solicitud.estaAprobado === true)  {",
        "      solicitud.esAprobadaEtiqueta = \"Aprobada\";",
        "    } else if(solicitud.estaAprobado === false) {",
        "      solicitud.esAprobadaEtiqueta = \"Rechazada\";",
        "    } else {",
        "      solicitud.esAprobadaEtiqueta = \"En curso\";",
        "    }",
        "  }",
        "}",
        "",
        "return $data.solicitudVacaciones;"
      ],
